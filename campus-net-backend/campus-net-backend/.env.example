PORT=3000
HOST=10.15.200.158
NODE_ENV=development

# Replace this before a demo if multiple devices will share the same LAN.
JWT_SECRET=change-me-local-dev-secret
JWT_EXPIRES_IN=7d

# JSON file storage keeps the school-contest prototype lightweight.
DATA_FILE=./data/local-db.json
PASSWORD_MIN_LENGTH=6

# Optional comma-separated origins for web debugging. Native Android apps do not need CORS.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
